# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=customer360
POSTGRES_PASSWORD=customer360secret
POSTGRES_DB=customer360_warehouse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPICS=customer-login,product-events,cart-events,purchase-events,payment-events,refund-events

# ── MinIO / Data Lake ─────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=customer360
MINIO_SECRET_KEY=customer360secret
MINIO_BRONZE_BUCKET=customer360-bronze
MINIO_SILVER_BUCKET=customer360-silver
MINIO_GOLD_BUCKET=customer360-gold

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# ── Spark ─────────────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077

# ── App ───────────────────────────────────────────────────────
EVENT_BATCH_SIZE=10000
TOTAL_EVENTS=10000000
NUM_CUSTOMERS=500000
NUM_PRODUCTS=50000

# ── LLM / RAG ─────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Qdrant VectorDB ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
